{
  // For more information, visit: https://go.microsoft.com/fwlink/?LinkId=733558
  "version": "2.0.0",
  "tasks": [
    {
      "label": "backend: dev",
      "type": "shell",
      "command": "yarn",
      "args": ["workspace", "@scryflemme/backend", "dev"],
      "isBackground": true
    },
    {
      "label": "frontend: dev",
      "type": "shell",
      "command": "yarn",
      "args": ["workspace", "@scryflemme/frontend", "dev"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "frontend: test",
      "type": "shell",
      "command": "yarn",
      "args": ["workspace", "@scryflemme/frontend", "test"],
      "isBackground": true,
      "problemMatcher": {
        "owner": "typescript",
        "pattern": "$tsc",
        "background": {
          "activeOnStart": true,
          "beginsPattern": {
            "regexp": "Changes detected"
          },
          "endsPattern": {
            "regexp": "bundle generation (complete|failed)"
          }
        }
      }
    },
    {
      "label": "backend: typecheck",
      "type": "shell",
      "command": "yarn",
      "args": ["workspace", "@scryflemme/backend", "typecheck"]
    }
  ]
}
